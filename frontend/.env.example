# FairSight Frontend — Environment Variables
# Copy this file to .env and fill in values for your environment.

# ──────────────────────────────────────────────────────────────────────────────
# Google OAuth
# Create a Web Application credential in https://console.cloud.google.com/apis/credentials
# Add your frontend origin (e.g. http://localhost:5173) as an Authorized JavaScript Origin.
# ──────────────────────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ──────────────────────────────────────────────────────────────────────────────
# Backend API URL (if you override the default detection in apiBaseUrl.ts)
# ──────────────────────────────────────────────────────────────────────────────
# VITE_API_URL=http://localhost:8000
