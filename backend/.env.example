# FairSight Backend — Environment Variables
# Copy this file to .env and fill in values for your environment.

# ──────────────────────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-use-a-long-random-string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fairsight
ALEMBIC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fairsight
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────────────────────────────────────
# Google OAuth
# Create a Web Application credential in https://console.cloud.google.com/apis/credentials
# Only GOOGLE_CLIENT_ID is strictly needed for ID-token verification.
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ──────────────────────────────────────────────────────────────────────────────
# Optional
# ──────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
ENVIRONMENT=development
LOG_LEVEL=INFO
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
