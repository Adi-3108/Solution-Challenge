# FairSight root environment template
# Copy this file to `.env` and fill in values for your local or deployed environment.

# ──────────────────────────────────────────────────────────────────────────────
# Database / Redis
# ──────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=fairsight
POSTGRES_USER=fairsight
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://fairsight:change-me@db:5432/fairsight
ALEMBIC_DATABASE_URL=postgresql+psycopg://fairsight:change-me@db:5432/fairsight
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────────────────────────────────────
# Authentication / tokens
# ──────────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
RESET_TOKEN_EXPIRE_MINUTES=30

# ──────────────────────────────────────────────────────────────────────────────
# Email / notifications
# ──────────────────────────────────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fairsight.local

# ──────────────────────────────────────────────────────────────────────────────
# Storage / files / frontend
# ──────────────────────────────────────────────────────────────────────────────
FILE_STORAGE_PATH=/app/uploads
PDF_REPORT_PATH=/app/uploads/reports
MAX_FILE_SIZE_MB=200
ALLOWED_FILE_RETENTION_DAYS=30
CORS_ORIGINS=http://localhost,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────────────────────────────────────────
# Runtime / logging / limits
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
WEBHOOK_TIMEOUT_SECONDS=5
RATE_LIMIT_PER_MINUTE=100
CELERY_TASK_ALWAYS_EAGER=false

# ──────────────────────────────────────────────────────────────────────────────
# Optional external integrations
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=25